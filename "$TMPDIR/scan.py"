import re
f = "App/ConnectionViewModel.swift"
lines = open(f).read().splitlines()
pat = re.compile(r'state = \.failed|state = \.shell|crashBanner = |degraded = ')
for i, ln in enumerate(lines):
    if pat.search(ln):
        # look at this line and up to 2 lines above for a DebugLog
        window = lines[max(0,i-2):i+1]
        if not any("DebugLog" in w for w in window):
            print(f"L{i+1}: {ln.strip()}")
