# Diagnostics syslog sink — local cert + captured logs (never commit)
/tools/syslog-sink/logs/
/tools/syslog-sink/cert/

# Rust / Cargo
/target/
# Cargo.lock IS committed — this crate ships into a shipped app binary.
# cargo-mutants output (on-demand mutation testing artifacts)
/mutants.out/
/mutants.out.old/

# SwiftPM
/.build/
.swiftpm/

# CI build artifacts (not source)
/SemicolynSSHCore.xcframework/
/Mosh.xcframework/
# Generated UniFFI Swift wrapper (produced by scripts/build-xcframework.sh)
/Sources/SemicolynSSHCoreFFI/
# Generated Xcode project (produced by `xcodegen generate` from project.yml)
/Semicolyn.xcodeproj/

# Secrets / data
.env
/data/

# Local dev/tooling state that must NEVER be committed — these are the user's
# shell rc files, IDE dirs, MCP registration, and Claude Code harness placeholders
# that a `git add -A` swept in once (commit 54465ba). Ignore so they can't recur.
/.mcp.json
/.claude/
/.idea/
/.vscode/
/.bashrc
/.bash_profile
/.bash_login
/.profile
/.zshrc
/.zprofile
/.gitconfig
/.ripgreprc
/.netrc
/.npmrc

# Scratch files that have been accidentally dropped in the repo root before: a
# UUID-named screenshot (5019F3B4-…png) and a literal "$TMPDIR/scan.py". Ignore
# root-level screenshots + the stray temp-script names so they can't recur.
/[0-9A-Fa-f]*-[0-9A-Fa-f]*-*.png
/"$TMPDIR"
/*.swp
/*.orig
.DS_Store

# Build-time seed artifacts (produced by scripts/build-seed.sh; bundled later)
/seeds/

# Superpowers scratch — SDD progress ledger + brainstorm visual-companion sessions
/.superpowers/

# Review-skill output (findings reports — regenerated on demand, not source)
/.code-review/
/.security-review/

# TODO.md is a committed project doc here — override the global
# core.excludesFile (~/.config/git/ignore) that ignores it by default.
# (CLAUDE.md is intentionally NOT overridden: it stays local-only per the
# global ignore.)
!/TODO.md
